# ──────────────────────────────────────────────────────────
# SelfMind Docker Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy this file to .env and customize the values.
# All paths are on the HOST machine — Docker maps them into the container.
#
# Quick start:
#   1. cp .env.example .env
#   2. Edit .env to match your environment
#   3. docker compose up -d
#   4. Open http://localhost:<SELFMIND_PORT>
# ──────────────────────────────────────────────────────────

# ── Port ──
SELFMIND_PORT=3002

# ── Data source profile ──
# Options: hermes, openclaw, honcho, or any custom profile defined in config.json
SOURCE_MODE=auto
ACTIVE_PROFILE=hermes

# ── Memory files ──
# Directory containing MEMORY.md, USER.md (§-separated entries)
# Default: ~/.hermes/memories (Hermes Agent)
MEMORIES_PATH=~/.hermes/memories

# ── Skills directory ──
# Directory containing SKILL.md files
# Default: ~/.hermes/skills (Hermes Agent)
SKILLS_PATH=~/.hermes/skills

# ── Wiki / Knowledge directory ──
# Directory containing wiki markdown files (entities, concepts, projects, etc.)
# Default: ~/Documents/aiworkspace/wiki — adjust to your wiki location
WIKI_PATH=~/Documents/aiworkspace/wiki

# ── Config file ──
# Path to config.json on the host machine
# If the file doesn't exist, SelfMind creates one with defaults
CONFIG_PATH=./config.json

# ── Honcho (optional) ──
# Honcho is a memory/identity layer. If not running, SelfMind skips it gracefully.
# Set HONCHO_ENABLED=false to disable Honcho data source entirely.
HONCHO_ENABLED=true
HONCHO_API_URL=http://host.docker.internal:8000/v3
HONCHO_WORKSPACE=hermes

# ── LLM (optional — for AI analysis features) ──
# Required only if you want to use the AI analysis tab.
# If not set, AI analysis features will be disabled.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini